---
import { ClientRouter } from "astro:transitions";
import "@/styles/global.css";
import { SITE, SOCIALS } from "@/consts";

const { title = "Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Building a better home."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://sarahj.pages.dev/" />
    <meta property="og:title" content="SarahJ | Portfolio" />
    <meta
      property="og:description"
      content="Outdoors by Default."
    />
    <meta property="og:image" content="/og-image.jpg" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content="SarahJ | Portfolio" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Sarah J | Ink & Code"
      href={`${Astro.site}rss.xml`}
    />

    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="antialiased h-full font-sans">
    <div class="flex flex-col min-h-full">
      <header class="w-full px-6 md:px-8">
        <div class="max-w-4xl mx-auto pt-8 md:pt-12">
          <div class="border-b-2 pb-6">
            <nav
              class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-6"
            >
              <a
                href="/"
                class="font-bold text-lg uppercase tracking-[0.2em] whitespace-nowrap"
              >
                {SITE.TITLE}
              </a>

              <ul class="flex gap-8 items-center font-sans">
                <li>
                  <a
                    href="/about"
                    class="text-xs font-semibold uppercase tracking-widest"
                    >About</a
                  >
                </li>
              </ul>
            </nav>
          </div>
        </div>
      </header>

      <main class="grow w-full px-6 md:px-8">
        <div class="max-w-4xl mx-auto py-8 md:py-12">
          <slot />
        </div>
      </main>

      <footer class="w-full px-6 md:px-8 mt-20 pb-12">
        <div class="max-w-4xl mx-auto border-t-2 pt-8">
          <div
            class="flex flex-col md:flex-row md:items-baseline justify-between gap-8"
          >
            <div class="flex gap-6">{
              SOCIALS.map((social) => (
                <a
                  href={social.HREF}
                  target={social.NAME === "RSS" ? "_self" : "_blank"}
                  rel="noopener noreferrer"
                  class="text-xs font-semibold uppercase tracking-widest hover:text-accent"
                >
                  {social.NAME}
                </a>
              ))
            }
            </div>
            <p class="text-xs font-semibold uppercase tracking-widest">
              <span>&copy;</span>
              {new Date().getFullYear()} — Sarah J
            </p>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
