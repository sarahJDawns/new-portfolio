---
import { ClientRouter } from "astro:transitions";
import "@/styles/global.css";
import { SITE, SOCIALS } from "@/consts";

const { title = "Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="alternate" type="application/rss+xml" title="Sarah J | Ink & Code" href={`${Astro.site}rss.xml`} />

    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="antialiased h-full font-sans">
    <div class="flex flex-col min-h-full">
      <header class="w-full px-6 md:px-8">
        <div class="max-w-4xl mx-auto pt-8 md:pt-12">
          <div class="border-b pb-6">
            <nav class="flex flex-col md:flex-row md:items-baseline gap-6 md:gap-12">
              <a href="/" class="font-bold text-lg uppercase tracking-[0.2em] whitespace-nowrap">
                {SITE.TITLE}
              </a>
              <ul class="flex gap-8 items-center font-sans">
                <li><a href="/projects" class="text-xs font-semibold uppercase tracking-widest">Code</a></li>
                <li><a href="/posts" class="text-xs font-semibold uppercase tracking-widest">Art</a></li>
                <li><a href="/about" class="text-xs font-semibold uppercase tracking-widest">About</a></li>
              </ul>
            </nav>
          </div>
        </div>
      </header>

      <main class="grow w-full px-6 md:px-8">
        <div class="max-w-4xl mx-auto py-8 md:py-12">
          <slot />
        </div>
      </main>

      <footer class="w-full px-6 md:px-8 mt-20 pb-12">
        <div class="max-w-4xl mx-auto border-t pt-8">
          <div class="flex flex-col md:flex-row md:items-baseline justify-between gap-8">
            <div class="flex gap-6">
              {SOCIALS.map((social) => (
                <a href={social.HREF} class="text-xs font-semibold uppercase tracking-widest">
                  {social.NAME}
                </a>
              ))}
            </div>
            <p class="text-xs font-semibold uppercase tracking-widest copyright-text">
              <span class="copy-symbol">&copy;</span> {new Date().getFullYear()} — Sarah J
            </p>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
