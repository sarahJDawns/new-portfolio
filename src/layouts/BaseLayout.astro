---
import {  ClientRouter } from "astro:transitions";
import "@/styles/global.css";

const { title = "Portfolio" } = Astro.props;
---
<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">

    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-stone-50 text-stone-800 antialiased h-full font-sans">
    <div class="flex flex-col min-h-full">
      <header class="p-6 md:p-8">
        <nav class="flex justify-between items-center max-w-4xl mx-auto">
          <a href="/" class="font-serif font-bold text-xl hover:text-sky-700 transition-colors">Sarah J</a>
          <ul class="flex gap-6 items-center font-sans">
            <li><a href="/about" class="hover:text-sky-700 transition-colors">About</a></li>
            <li><a href="/projects" class="hover:text-sky-700 transition-colors">Projects</a></li>
            <li><a href="/posts" class="hover:text-sky-700 transition-colors">Art</a></li>
          </ul>
        </nav>
      </header>
      <main class="grow">
        <div class="max-w-4xl mx-auto p-6 md:p-8">
          <slot />
        </div>
      </main>
      <footer class="p-6 md:p-8 text-center text-stone-500 text-sm font-sans">
        <p>&copy; {new Date().getFullYear()} - Ink & Code</p>
      </footer>
    </div>
  </body>
</html>