---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const projects = await getCollection("projects");
  const allContent = [...posts, ...projects];

  const allTags = [
    ...new Set(allContent.flatMap((item) => item.data.tags || [])),
  ];

  return allTags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter((p) => (p.data.tags || []).includes(tag)),
      projects: projects.filter((p) => (p.data.tags || []).includes(tag)),
    },
  }));
}

const { tag, posts, projects } = Astro.props;
---

<BaseLayout title={`Tag: ${tag}`}>
  <a href="/tags" class=" hover:underline mb-8 block transition-colors">
    &larr; All Tags
  </a>

  <header class="mb-12">
    <h1 class="text-4xl font-bold">
      Filtered by <span class="tag-header-pill">#{tag}</span>
    </h1>
  </header>

  {
    projects.length > 0 && (
      <section class="mb-16">
        <h2 class="text-xl font-semibold mb-6 border-b">Projects</h2>
        <div class="space-y-8">
          {projects.map((project) => (
            <article>
              <a href={`/projects/${project.id}`} class="group block">
                <h3 class="text-xl font-semibold transition-colors">
                  {project.data.title}
                </h3>
                <p class="italic text-sm">{project.data.description}</p>
              </a>
            </article>
          ))}
        </div>
      </section>
    )
  }

  {
    posts.length > 0 && (
      <section>
        <h2 class="text-xl font-semibold mb-6 border-b">Posts</h2>
        <div class="space-y-8">
          {posts.map((post) => (
            <article>
              <a href={`/posts/${post.id}`} class="group block">
                <h3 class="text-xl font-semiboldtransition-colors">
                  {post.data.title}
                </h3>
                {post.data.description && (
                  <p class="italic text-sm mb-2">{post.data.description}</p>
                )}
              </a>
            </article>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>