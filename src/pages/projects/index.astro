---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE, PROJECTS } from "@/consts";

const allProjects: CollectionEntry<"projects">[] = await getCollection("projects");

const projects = allProjects.sort(
  (a: CollectionEntry<"projects">, b: CollectionEntry<"projects">) => 
    new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

const title = `${SITE.TITLE} | ${PROJECTS.TITLE}`;

---

<BaseLayout title={title}>
  <section class="mb-16">
    <h1 class="text-4xl font-bold mb-2">{PROJECTS.TITLE}</h1>
    <p class="text-lg italic">
      {PROJECTS.DESCRIPTION}
    </p>
  </section>

  <section>
    <div class="space-y-10">
      {
        projects.map(
          (
            project,
          ) => (
            <article>
              <h3 class="text-xl font-medium mb-1">
                  <a href={`/projects/${project.id}`} class="transition-colors ">
                    {project.data.title}
                  </a>
                </h3>
                <p class="mb-3">{project.data.description}</p>
                <div class="flex gap-2 my-4">
                  {(project.data.tags ?? []).map((tag) => (
                    <a 
                      href={`/tags/${tag}`} 
                      class="text-sm font-medium transition-colors"
                    >
                      #{tag}
                    </a>
                  ))}
                </div>
              <div class="flex gap-4">
                {
                  project.data.links?.map(((link: { name: string; url: string }) => (
                    <a
                      href={link.url}
                      class="hover:underline text-sm font-medium"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {link.name} &rarr;
                    </a>
                  )))
                }
              </div>
            </article>
          ),
        )
      }
    </div>
  </section>
</BaseLayout>
