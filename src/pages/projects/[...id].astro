---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content"; // The secret sauce
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  // Add ': any' or ': CollectionEntry<"projects">' here
  return projects.map((project: any) => ({
    params: { id: project.id },
    props: { project },
  }));
}

// Tell TypeScript exactly what 'project' is
const { project } = Astro.props as { project: CollectionEntry<"projects"> };
const { Content } = await render(project);
---

<BaseLayout title={project.data.title}>
  <article class="prose prose-zinc mx-auto">
    <header class="mb-8">
      <h1 class="text-3xl font-bold">{project.data.title}</h1>
      <p class="text-zinc-500 italic">{project.data.description}</p>
    </header>

    <div class="mt-8">
      <Content />
    </div>
  </article>
</BaseLayout>
