---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="404: Not Found">
  <main class="flex flex-col items-start justify-center min-h-[50vh] px-6 md:px-8">
    <div class="max-w-4xl w-full mx-auto">
      
      <h1 class="text-6xl md:text-8xl font-bold uppercase tracking-tighter mb-4">
        404
      </h1>

      <div class="border-l-2 pl-6 md:pl-8 py-2">
        <p class="text-lg font-medium mb-6">
          This page appears to be missing from the collection.
        </p>
        
        <a 
          href="/" 
          class="text-xs font-bold uppercase tracking-[0.2em] transition-colors"
        >
          ← Return 
        </a>
      </div>

    </div>
  </main>
</BaseLayout>