---
import BaseLayout from "@/layouts/BaseLayout.astro";
---
<BaseLayout title="About">
  <article class="prose prose-zinc">
    <h1 class="text-3xl font-bold mb-6">About Me</h1>
    <p>This is where your story goes. Minimalist, focused, and high-performance.</p>
    
    <h2 class="text-xl font-semibold mt-8 mb-4">The Stack</h2>
    <ul class="list-disc pl-5 space-y-2 text-zinc-600">
      <li>Framework: Astro 5</li>
      <li>Styling: Tailwind v4</li>
      <li>Runtime: Bun</li>
      <li>Editor: Zed</li>
    </ul>
  </article>
</BaseLayout>