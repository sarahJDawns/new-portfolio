---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE, POSTS } from "@/consts";

const allPosts: CollectionEntry<"posts">[] = await getCollection("posts");

const posts = allPosts.sort(
  (a: CollectionEntry<"posts">, b: CollectionEntry<"posts">) =>
    new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf(),
);

const title = `${SITE.TITLE} | ${POSTS.TITLE}`;
---

<BaseLayout title={title}>
  <section class="mb-16">
    <h1 class="text-4xl font-bold mb-2">{POSTS.TITLE}</h1>
    <p class="text-lg italic">
      {POSTS.DESCRIPTION}
    </p>
  </section>

  <section>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        posts.map((post) => (
          <a
            href={`/posts/${post.id}`}
            class="block p-4 border rounded-lg transition-colors"
          >
            <h3 class="font-medium text-lg mb-1">{post.data.title}</h3>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
